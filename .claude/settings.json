{
    "permissions": {
        "allow": [
            "Bash",
            "Edit",
            "Write"
        ],
        "deny": [
            "Bash(rm -rf /)",
            "Bash(rm -rf ~)",
            "Bash(rm -rf .git)",
            "Bash(drop database)",
            "Bash(truncate table)",
            "Bash(sudo *)",
            "Bash(chmod 777 /etc/*)",
            "Write(/etc/**)",
            "Write(~/.ssh/**)",
            "Read(~/.mysql_*)",
            "Read(~/.pgpass)",
            "Read(.env)",
            "Read(*id_rsa*)",
            "Bash(curl * | sh)",
            "Bash(wget * -O- | bash)",
            "Bash(cron *)",
            "Bash(systemctl *)"
        ]
    }
}